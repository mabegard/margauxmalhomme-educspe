# Variables d'environnement (exemple)

# Optionnel — mesure d'audience avec Plausible (sans publicité).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=margauxmalhomme.com

NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optionnel — balise de vérification Google Search Console (meta google-site-verification).
# Search Console → Paramètres → Validation → Balise HTML → copier la valeur du content="...".
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=votre_code_ici

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Actions SEO manuelles (hors code) ---
# 1. Search Console : soumettre https://margauxmalhomme.com/sitemap.xml
# 2. Search Console : demander l'indexation de /, /qui-suis-je, /contact, /tarifs, /bilans
# 3. Google Business Profile : catégorie « Éducateur spécialisé », site margauxmalhomme.com
# 4. Instagram / LinkedIn : lien margauxmalhomme.com dans la bio (voir src/lib/seo.ts → SOCIAL_BIO_SUGGESTION)
# 5. Suivi mensuel : Search Console → Performances → requêtes « éduc », « spécialisé », « Clermont »
